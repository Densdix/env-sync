{
  "name": "env-sync",
  "displayName": "Env Sync",
  "description": "Synchronize .env files across devices using Firebase Realtime Database with live visual highlights",
  "version": "1.0.0",
  "publisher": "Densdix",
  "icon": "resources/sync.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Densdix/env-sync"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "env",
    "dotenv",
    "sync",
    "firebase",
    "monorepo",
    "environment variables"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Env Sync",
      "properties": {
        "envSync.databaseUrl": {
          "type": "string",
          "default": "",
          "description": "Firebase Realtime Database URL (e.g. https://your-db-default-rtdb.firebaseio.com/)"
        },
        "envSync.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable automatic sync of .env files"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "envSync-explorer",
          "title": "Env Sync",
          "icon": "$(sync)"
        }
      ]
    },
    "views": {
      "envSync-explorer": [
        {
          "id": "envSyncHistory",
          "name": "History of Changes"
        }
      ]
    },
    "commands": [
      {
        "command": "envSync.refreshHistory",
        "title": "Refresh History",
        "icon": "$(refresh)"
      },
      {
        "command": "envSync.pullFile",
        "title": "Pull from Database",
        "icon": "$(cloud-download)"
      },
      {
        "command": "envSync.pullAll",
        "title": "Pull All from Database",
        "icon": "$(cloud-download)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "envSync.refreshHistory",
          "when": "view == envSyncHistory",
          "group": "navigation@1"
        },
        {
          "command": "envSync.pullAll",
          "when": "view == envSyncHistory",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "envSync.pullFile",
          "when": "view == envSyncHistory && viewItem == fileItem",
          "group": "inline"
        },
        {
          "command": "envSync.pullFile",
          "when": "view == envSyncHistory && viewItem == fileItem",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "echo 'No linting configured'",
    "test": "echo 'No tests configured'",
    "vsix": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.11.18",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.0.2"
  }
}
